modules = ["python-3.11", "nodejs-20"]
[agent]
expertMode = true
integrations = ["python_gemini:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Book Extractor"

[[workflows.workflow]]
name = "Book Extractor"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python src/book_extractor.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5904
externalPort = 80
