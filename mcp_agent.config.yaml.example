# MCP Agent Configuration Example
# Copy this file to mcp_agent.config.yaml and configure it for your setup

execution_engine: asyncio
logger:
  transports: [console, file]
  level: info
  progress_display: true

mcp:
  servers:
    # Brave Search MCP Server (requires BRAVE_API_KEY in secrets - used as last resort)
    brave-search:
      command: npx
      args:
        - "-y"
        - "@modelcontextprotocol/server-brave-search"
      env:
        XDG_CONFIG_HOME: /tmp/.config
        HOME: /tmp

google:
  # Default Gemini model for the agent
  default_model: "gemini-2.0-flash-exp"
