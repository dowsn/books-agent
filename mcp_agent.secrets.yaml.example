# MCP Agent Secrets Example
# Copy this file to mcp_agent.secrets.yaml and add your actual API keys
# NEVER commit mcp_agent.secrets.yaml to git (it's in .gitignore)

# Google Gemini API Key (required)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY: your_gemini_api_key_here

# Brave Search API Key (optional - for last-resort web search fallback)
# Get your key from: https://brave.com/search/api/
BRAVE_API_KEY: your_brave_api_key_here

# Firecrawl API Key (optional - enables full JavaScript rendering for KVK catalog)
# Free tier: 500 credits/month (each KVK scrape = 1 credit)
# Get your key from: https://www.firecrawl.dev
FIRECRAWL_API_KEY: your_firecrawl_api_key_here
